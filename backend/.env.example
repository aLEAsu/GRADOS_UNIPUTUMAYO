# ============================================
# Plataforma Grados UTP - Variables de Entorno
# ============================================
# COPIAR este archivo como .env.development o .env.production
# y rellenar con valores reales. NUNCA versionar los .env reales.

# --- App ---
NODE_ENV=development
PORT=4000

# --- Database ---
DATABASE_URL=postgresql://itp_admin:CHANGE_ME@localhost:5432/plataforma_grados

# --- JWT (CAMBIAR EN PRODUCCIÓN) ---
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:4200

# --- File Uploads ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# --- Logging ---
LOG_LEVEL=debug

# --- Google OAuth (obtener en https://console.cloud.google.com) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
FRONTEND_CALLBACK_URL=http://localhost:4200/auth/callback

# --- Email (MailHog para desarrollo) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@itp.edu.co

# --- Digital Signatures ---
SIGNATURE_PRIVATE_KEY_PATH=./certs/private-key.pem
SIGNATURE_CERT_PATH=./certs/certificate.pem

# --- External API (ITP Student System) ---
ITP_API_BASE_URL=https://api.example.com
ITP_API_KEY=
ITP_INTEGRATION_ENABLED=false

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
